# Ghostty config - migrated from iTerm2 Dracula profile
# Docs: https://ghostty.org/docs/config

# === Theme ===
theme = Catppuccin Mocha

# --- Dracula (previous theme) ---
# theme = Dracula
# background = #1e1f29
# cursor-color = #bbbbbb
# cursor-text = #ffffff
# palette = 0=#000000
# palette = 7=#bbbbbb
# palette = 8=#f9f9f4
# palette = 9=#ff5555
# palette = 11=#f1fa8c
# palette = 12=#bd93f9
# palette = 13=#ff79c6
# palette = 14=#8be9fd

# === Font ===
font-family = MesloLGS NF
font-size = 12
font-thicken = true

# === Spacing ===
# iTerm2 vertical spacing was 1.09
adjust-cell-height = 9%

# === Window ===
window-height = 25
window-width = 80
background-opacity = 0.91
#background-opacity = 1.00
window-theme = dark

# === Cursor ===
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# === Scrollback ===
scrollback-limit = 10000000

# === Bell ===
# Ghostty doesn't have a visual bell option; audible bell is the default

# === Input ===
# iTerm2 option key was set to Normal (not Esc+)
macos-option-as-alt = false

# === Clipboard ===
copy-on-select = false

# === Keybindings ===
# Cmd+Enter = toggle fullscreen (matches iTerm2 global keybind)
keybind = cmd+enter=toggle_fullscreen

# Splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+up=goto_split:top
keybind = cmd+opt+down=goto_split:bottom
keybind = cmd+opt+left=goto_split:left
keybind = cmd+opt+right=goto_split:right


# Uncomment this to prevent Ghostty from re-establishing saved state
# this is what i had to do when Claude and I got into a recursive hell
# of opening tabs, beware.

# window-save-state = never
